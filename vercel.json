{
  "version": 2,
  "buildCommand": "npm run build:client",
  "outputDirectory": "client/dist",
  "functions": {
  "index.js": {
    "maxDuration": 60
  }
}
    }
  },
  "routes": [
    {
  "src": "/api/(.*)",
  "dest": "/index.js"
}
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
